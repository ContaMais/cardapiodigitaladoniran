    "cardapio": {
      ".read": true,
      ".write": true
    },
    "reservas": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'dono' || root.child('users').child(auth.uid).child('role').val() === 'contribuidor')"
    },
    "mapas": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'dono' || root.child('users').child(auth.uid).child('role').val() === 'contribuidor')"
    },
    "historico_timeline": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'dono'",
      "$eventId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'dono' || root.child('users').child(auth.uid).child('role').val() === 'contribuidor')",
        ".validate": "newData.hasChildren(['timestamp', 'tipo'])"
      }
    }
  }
}
